{
  "name": "beo-website-storybook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "storybook": "npx concurrently 'npm:watch:*'",
    "watch:storybook": "storybook dev -p 6008",
    "watch:tailwind": "node ./src/utils/tailwind-watch.mjs",
    "build-storybook": "storybook build",
    "build:tailwind": "node ./src/utils/tailwind-build.mjs",
    "build:components": "node ./src/utils/build-components.mjs",
    "build:dist": "npm run build:tailwind && npm run build:components"
  },
  "dependencies": {
    "lit": "^3.3.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/web-components-vite": "^10.3.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "cssnano": "^7.1.3",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "storybook": "^10.3.3",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.1"
  }
}
